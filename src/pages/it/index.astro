---
import BaseLayout from '../../layouts/base-layout.astro';
import ComboSearch from '../../components/search/combo-search';
import partsData from '../../../data/parts.json';
import combosData from '../../../data/combos.json';
import it from '../../i18n/it.json';

const locale = 'it';
---

<BaseLayout>
  <ComboSearch
    client:load
    parts={partsData}
    combos={combosData}
    locale={locale}
    translations={it}
  />
</BaseLayout>
