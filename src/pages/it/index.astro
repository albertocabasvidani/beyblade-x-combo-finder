---
import BaseLayout from '../../layouts/base-layout.astro';
import ComboSearch from '../../components/search/combo-search';
import { t } from '../../i18n/ui';
import partsData from '../../../data/parts.json';
import combosData from '../../../data/combos.json';
import productsData from '../../../data/products.json';
import { buildProductLookup } from '../../lib/amazon';
import it from '../../i18n/it.json';

const locale = 'it';
const productLookup = buildProductLookup(productsData);
const amazonConfig = {
  tld: 'it',
  tag: import.meta.env.AMAZON_TAG_IT ?? '',
};
---

<BaseLayout>
  <div class="mb-8 text-center">
    <h1 class="mb-2 text-3xl font-bold text-yellow-400">{t(locale, 'search.title')}</h1>
    <p class="text-sm text-gray-400">{t(locale, 'search.subtitle')}</p>
  </div>

  <ComboSearch
    client:load
    parts={partsData}
    combos={combosData}
    locale={locale}
    translations={it}
    amazonConfig={amazonConfig}
    productLookup={productLookup}
  />
</BaseLayout>
