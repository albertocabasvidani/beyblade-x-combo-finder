---
import { t } from '../../i18n/ui';
import type { Locale } from '../../lib/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<footer class="border-t border-border bg-surface px-4 py-6 text-center text-xs text-muted-2">
  <p class="mb-2">{t(locale, 'footer.dataNote')}</p>
  <p>&copy; {new Date().getFullYear()} Beyblade X Combo Finder</p>
</footer>
