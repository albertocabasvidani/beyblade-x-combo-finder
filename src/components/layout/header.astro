---
import { t } from '../../i18n/ui';
import type { Locale } from '../../lib/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const otherLocale = locale === 'en' ? 'it' : 'en';
const currentPath = Astro.url.pathname.replace(`/${locale}`, '');
---

<header class="border-b border-gray-800 bg-gray-900">
  <nav class="mx-auto flex max-w-4xl items-center justify-between px-4 py-3">
    <a href={`/${locale}/`} class="text-lg font-bold text-yellow-400">
      BeyCombo
    </a>
    <div class="flex items-center gap-4">
      <a href={`/${locale}/`} class="text-sm text-gray-300 hover:text-white">
        {t(locale, 'nav.home')}
      </a>
      <a
        href={`/${otherLocale}${currentPath}`}
        class="rounded border border-gray-600 px-2 py-1 text-xs font-medium text-gray-300 hover:bg-gray-700 hover:text-white"
      >
        {otherLocale.toUpperCase()}
      </a>
    </div>
  </nav>
</header>
