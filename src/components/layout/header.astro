---
import { t } from '../../i18n/ui';
import type { Locale } from '../../lib/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="border-b border-border-strong bg-surface">
  <nav class="mx-auto flex max-w-[1180px] items-center justify-between px-4 py-3 lg:px-10">
    <a href={`${base}/`} class="flex items-center gap-2">
      <span
        class="grid h-7 w-7 place-items-center bg-gold font-display text-[19px] leading-none text-gold-ink"
        style="transform: skewX(-10deg)"
      >
        <span style="transform: skewX(10deg)">X</span>
      </span>
      <span class="font-display text-[17px] uppercase tracking-[0.02em] text-text lg:text-[21px]">Combo Finder</span>
    </a>

    <div class="flex items-center gap-3 lg:gap-6">
      <a
        href={`${base}/`}
        class="font-mono text-[11px] uppercase tracking-[0.08em] text-gold lg:text-xs"
      >
        {t(locale, 'nav.home')}
      </a>
      <a
        href={`${base}/about/`}
        class="font-mono text-[11px] uppercase tracking-[0.08em] text-muted transition-colors hover:text-text lg:text-xs"
      >
        {t(locale, 'nav.howScoring')}
      </a>

      <button
        id="theme-toggle"
        type="button"
        aria-label={t(locale, 'theme.toggle')}
        class="grid h-8 w-8 place-items-center rounded-lg border border-border text-muted transition-colors hover:text-text"
      >
        <svg class="theme-icon-dark" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <svg class="theme-icon-light" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5 19 19M5 19l1.5-1.5M17.5 6.5 19 5" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
      document.documentElement.dataset.theme = next;
      try {
        localStorage.setItem('theme', next);
      } catch (e) {}
    });
  })();
</script>
